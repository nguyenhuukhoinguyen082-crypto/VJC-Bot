# Required - use long random strings (openssl rand -hex 32)
API_KEY=your_api_key_min_16_chars
SECRET_KEY=your_secret_key_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_PER_MINUTE=60
CSRF_SECRET_KEY=your_csrf_secret_key_here
CSRF_TOKEN_EXPIRE_MINUTES=60
# Comma-separated frontend origins (must match exactly, no trailing slash)
CORS_ORIGINS=http://localhost:3000,https://bamboo-airways.vercel.app
# Required for Vercel + separate API host (cross-origin cookies)
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_SAMESITE=none
ELEVATED_ROLE_IDS=123456789012345678
DISCORD_BOT_TOKEN=token
DISCORD_GUILD_ID=1493906141535801415
DISCORD_INVITE_URL=https://discord.gg/pFgPqSKwFp
BACKEND_API_URL=

# Voice announcements (gTTS) — requires FFmpeg on PATH and outbound internet
DEFAULT_VOICE_CHANNEL_ID=1503003631027486812
GTTS_LANG=en
# Optional: full path to ffmpeg.exe if not on PATH (Windows example)
# FFMPEG_EXECUTABLE=C:/ffmpeg/bin/ffmpeg.exe
